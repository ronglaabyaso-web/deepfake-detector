# คัดลอกไฟล์นี้เป็น .env แล้วเติมค่า (ทุกอย่างไม่บังคับ — ไม่มี key ก็รันได้ในโหมดกฎพื้นฐาน)

# ---- AI (อธิบายผล/แชท/วิเคราะห์ข้อความ) ----
# ผู้ให้บริการ: auto | gemini | claude | ollama | none
# auto = ลองตามลำดับ gemini → claude → ollama → none (โหมดกฎพื้นฐาน)
AI_PROVIDER=auto

# Gemini ฟรี: ขอ key ได้ที่ https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Claude (ถ้ามี)
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-haiku-4-5-20251001

# Ollama (รันในเครื่อง ฟรี)
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# ---- ตรวจ Deepfake วิดีโอ ----
# ใส่หลายโมเดลคั่นด้วย comma → ระบบจะเฉลี่ยคะแนนจากทุกโมเดล (ensemble)
DEEPFAKE_MODEL_ID=prithivMLmods/deepfake-detector-model-v1,prithivMLmods/Deepfake-Detect-Siglip2

# ตรวจคลิปแบบ "ไม่ต้องมี torch" (เหมาะกับเซิร์ฟเวอร์แรมน้อย เช่น Render ฟรี):
# ตั้ง token นี้ → ระบบจะให้คะแนนผ่าน Hugging Face Inference API แทนการโหลดโมเดลในเครื่อง
# ขอ token ฟรีที่ https://huggingface.co/settings/tokens (สิทธิ์ read พอ)
# ถ้าไม่ตั้ง + มี torch ในเครื่อง → ใช้โหมดในเครื่องอัตโนมัติ
DEEPFAKE_HF_TOKEN=
# ขอบครอปรอบใบหน้า (0.2 = 20%)
FACE_MARGIN=0.2
# จำนวนเฟรมสูงสุดที่ตัดมาวิเคราะห์ต่อคลิป
MAX_FRAMES=16
# ความยาวคลิปสูงสุดที่ยอมดาวน์โหลด (วินาที)
MAX_VIDEO_SECONDS=180

# ---- เซิร์ฟเวอร์ ----
HOST=0.0.0.0
PORT=8000
